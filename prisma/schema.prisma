// Prisma schema — I.S Painting Business Manager

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────

enum UserRole {
  admin
  employee
}

enum JobStatus {
  estimate
  sent
  approved
  active
  completed
  on_hold
  cancelled
}

enum JobType {
  interior
  exterior
  both
  commercial
  other
}

enum OpportunityPipeline {
  sales
  not_interested
}

enum OpportunityStage {
  new_lead
  onboarding
  not_answered
  follow_up
  estimate_sent
  approval
  service_delivery
  review
  no_reply
  lost
  not_qualified
}

enum OpportunityStatus {
  open
  won
  lost
}

enum ProposalStatus {
  draft
  ready
  sent
  viewed
  approved
  declined
  follow_up
  converted
}

enum ProposalCategory {
  interior_painting
  exterior_painting
  deck_restoration
  pergola_restoration
  trim_restoration
  cabinet_refinishing
  wallpaper_removal
  drywall_repair
  commercial_painting
  new_construction
  property_maintenance
  custom
}

enum ProposalTemplate {
  interior_painting
  exterior_painting
  cabinet_refinishing
  deck_restoration
  pergola_restoration
  trim_restoration
  wallpaper_removal
  drywall_repair
  commercial_painting
  new_construction
  property_maintenance
}

enum ProposalType {
  residential
  commercial
  restoration
  maintenance
  new_construction
  custom
}

enum InvoiceStatus {
  draft
  sent
  partial
  paid
  overdue
  cancelled
}

enum PaymentMethod {
  check
  cash
  credit_card
  bank_transfer
  other
}

enum PaymentStatus {
  received
  deposited
  cleared
  bounced
}

enum ExpenseCategory {
  materials
  labor
  equipment
  subcontractor
  travel
  office
  other
}

enum ExpenseStatus {
  pending
  approved
  rejected
}

enum InventoryCategory {
  paint
  primer
  caulk
  tape
  tools
  supplies
  other
}

enum AutomationName {
  follow_up
  not_answered
  review_request
  form_submit
}

enum AutomationStatus {
  active
  paused
  completed
  failed
}

enum AutomationChannel {
  sms
  email
}

enum WorkType {
  job_site
  shop
  office
  travel
  meeting
  training
  other
}

enum TimeReviewStatus {
  pending
  approved
  rejected
}

enum TimeRateType {
  regular
  special
  travel
  overtime
}

enum JobTravelRateType {
  regular
  special
  custom
}

// ─── USERS ───────────────────────────────────────────

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String
  password   String
  role       UserRole @default(employee)
  phone      String?  @db.VarChar(20)
  hourlyRate Decimal? @db.Decimal(10, 2)
employeeRole String? @db.VarChar(50)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  timeEntries           TimeEntry[]
  approvedTimeEntries   TimeEntry[]             @relation("ApprovedTimeEntries")
  expenses              Expense[]               @relation("SubmittedExpenses")
  approvedExpenses      Expense[]               @relation("ApprovedExpenses")
  payments              Payment[]
  invoicesCreated       Invoice[]
  auditLogs             AuditLog[]
  assignedOpportunities Opportunity[]
  jobAssignments        EmployeeJobAssignment[]

  @@index([role])
  @@index([isActive])
}

// ─── CUSTOMERS ───────────────────────────────────────

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  email     String?
  phone     String?   @db.VarChar(30)
  address   String?
  city      String?   @db.VarChar(100)
  state     String?   @db.VarChar(50)
  zipCode   String?   @db.VarChar(20)
  source    String?   @db.VarChar(100)
  tags      String[]
  notes     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
externalId String? @db.VarChar(100)

  jobs              Job[]
  proposals         Proposal[]
  opportunities     Opportunity[]
  invoices          Invoice[]
  reviewSubmissions ReviewSubmission[]

 @@index([deletedAt])
@@index([name])
@@unique([externalId])
}

// ─── JOBS ────────────────────────────────────────────

model Job {
  id             Int       @id @default(autoincrement())
  customerId     Int
  opportunityId  Int?      @unique
  estimateNumber String    @unique @db.VarChar(20)
  name           String
  status         JobStatus @default(estimate)
  jobType        JobType   @default(interior)

  address        String?
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(50)
  zipCode        String?  @db.VarChar(20)
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)
  geofenceRadius Int      @default(100)

  scopeOfWork String? @db.Text
  notes       String? @db.Text

  materialsBudget      Decimal @default(0) @db.Decimal(12, 2)
  laborBudget          Decimal @default(0) @db.Decimal(12, 2)
  subcontractorBudget  Decimal? @db.Decimal(10, 2)
  wcPercent            Decimal @default(0) @db.Decimal(5, 2)
  glPercent            Decimal @default(0) @db.Decimal(5, 2)
  overheadPercent      Decimal @default(0) @db.Decimal(5, 2)
  markupPercent        Decimal @default(0) @db.Decimal(5, 2)
  taxPercent           Decimal @default(0) @db.Decimal(5, 2)
  subtotalBeforeMarkup Decimal @default(0) @db.Decimal(12, 2)
  totalEstimate        Decimal @default(0) @db.Decimal(12, 2)
  contractAmount       Decimal @default(0) @db.Decimal(12, 2)
  budgetLocked         Boolean @default(false)
  specialPayEnabled    Boolean @default(false)
  hourlyRateAdjustment Decimal @default(0) @db.Decimal(10, 2)
  travelPayEnabled     Boolean @default(false)
  defaultTravelHours   Decimal @default(0) @db.Decimal(8, 2)
  travelRateType       JobTravelRateType @default(regular)
  customTravelRate     Decimal? @db.Decimal(10, 2)

  priceBreakdownJson Json?

  sentAt     DateTime?
  approvedAt DateTime?
  startDate  DateTime?
  endDate    DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
externalId String? @db.VarChar(100)

  customer    Customer                @relation(fields: [customerId], references: [id])
  opportunity Opportunity?            @relation(fields: [opportunityId], references: [id])
  materials   JobMaterial[]
  labor       JobLabor[]
  timeEntries TimeEntry[]
  expenses    Expense[]
  invoices    Invoice[]
  payments    Payment[]
  assignments EmployeeJobAssignment[]
  paintColors JobPaintColor[]

  @@index([customerId])
  @@index([status])
  @@index([deletedAt])
  @@index([status, deletedAt])
@@unique([externalId])
}

model JobMaterial {
  id              Int      @id @default(autoincrement())
  jobId           Int
  inventoryItemId Int?
  name            String
  description     String?
  quantity        Decimal  @db.Decimal(10, 2)
  unit            String   @db.VarChar(50)
  unitCost        Decimal  @db.Decimal(10, 2)
  totalCost       Decimal  @db.Decimal(12, 2)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([jobId])
}

model JobLabor {
  id         Int      @id @default(autoincrement())
  jobId      Int
  role       String   @db.VarChar(100)
  employeeId Int?
  hours      Decimal  @db.Decimal(8, 2)
  hourlyCost Decimal  @db.Decimal(8, 2)
  totalCost  Decimal  @db.Decimal(12, 2)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model EmployeeJobAssignment {
  id         Int      @id @default(autoincrement())
  userId     Int
  jobId      Int
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model JobPaintColor {
  id        Int      @id @default(autoincrement())
  jobId     Int
  area      String   @db.VarChar(100)
  colorName String   @db.VarChar(150)
  brand     String?  @db.VarChar(100)
  finish    String?  @db.VarChar(100)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ─── INVENTORY ───────────────────────────────────────

model InventoryItem {
  id            Int               @id @default(autoincrement())
  name          String
  description   String?
  category      InventoryCategory
  unit          String            @db.VarChar(50)
  costPerUnit   Decimal           @db.Decimal(10, 2)
  sellingPrice  Decimal?          @db.Decimal(10, 2)
  currentStock  Decimal           @default(0) @db.Decimal(10, 2)
  minStockLevel Decimal           @default(0) @db.Decimal(10, 2)
  supplier      String?
  sku           String?           @db.VarChar(100)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  jobMaterials JobMaterial[]

  @@index([category])
  @@index([isActive])
  @@index([name])
}

// ─── OPPORTUNITIES ───────────────────────────────────

model Opportunity {
  id                 Int                 @id @default(autoincrement())
  customerId         Int
  name               String
  pipeline           OpportunityPipeline @default(sales)
  stage              OpportunityStage    @default(new_lead)
  status             OpportunityStatus   @default(open)
  leadValue          Decimal?            @db.Decimal(12, 2)
  source             String?             @db.VarChar(100)
  assignedToId       Int?
  notes              String?             @db.Text
  lastStageChangedAt DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  customer       Customer        @relation(fields: [customerId], references: [id])
  job            Job?
  assignedTo     User?           @relation(fields: [assignedToId], references: [id])
  automationRuns AutomationRun[]

  @@index([customerId])
  @@index([pipeline, stage])
  @@index([stage])
}

model Proposal {
  id                  Int            @id @default(autoincrement())
  proposalNumber      String         @unique @db.VarChar(20)
  customerId          Int
  projectName         String
  address             String?
  city                String?        @db.VarChar(100)
  state               String?        @db.VarChar(50)
  zipCode             String?        @db.VarChar(20)
  status              ProposalStatus @default(draft)
  proposalTemplate    ProposalTemplate?
  proposalType        ProposalType?
  projectSummary      String?        @db.Text
  scopeOfWork         String?        @db.Text
  includedWork        String?        @db.Text
  exclusions          String?        @db.Text
  importantNotes      String?        @db.Text
  recommendations     String?        @db.Text
  closingText         String?        @db.Text
  proposalBody        String?        @db.Text
  aiAssistantNotes    String?        @db.Text
  notes               String?        @db.Text
  emailBody           String?        @db.Text
  referencesText      String?        @db.Text
  termsAndConditions  String?        @db.Text
  paymentSchedule     String?        @db.Text
  materialsBudget     Decimal        @default(0) @db.Decimal(12, 2)
  laborBudget         Decimal        @default(0) @db.Decimal(12, 2)
  subcontractorBudget Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal        @default(0) @db.Decimal(12, 2)
  expectedStartDate   DateTime?
  expectedEndDate     DateTime?
  sentAt              DateTime?
  approvedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  customer    Customer             @relation(fields: [customerId], references: [id])
  sections    ProposalSection[]
  options     ProposalOption[]
  attachments ProposalAttachment[]
  paintColors ProposalPaintColor[]

  @@index([customerId])
  @@index([status])
}

model ProposalExample {
  id                  Int              @id @default(autoincrement())
  title               String
  proposalCategory    ProposalCategory
  proposalType        ProposalType?
  description         String?          @db.Text
  fullProposalContent String           @db.Text
  tags                String[]
  notes               String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([proposalCategory])
  @@index([proposalType])
  @@index([title])
}

model ProposalPaintColor {
  id         Int      @id @default(autoincrement())
  proposalId Int
  area       String   @db.VarChar(100)
  colorName  String   @db.VarChar(150)
  brand      String?  @db.VarChar(100)
  product    String?  @db.VarChar(150)
  colorCode  String?  @db.VarChar(100)
  finish     String?  @db.VarChar(100)
  notes      String?  @db.Text
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([proposalId, sortOrder])
}

model ProposalSection {
  id          Int      @id @default(autoincrement())
  proposalId  Int
  templateKey String?  @db.VarChar(100)
  title       String
  description String?  @db.Text
  bulletItems String[]
  notes       String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([proposalId, sortOrder])
}

model ProposalOption {
  id          Int      @id @default(autoincrement())
  proposalId  Int
  title       String
  description String?  @db.Text
  scope       String?  @db.Text
  price       Decimal? @db.Decimal(12, 2)
  isVisible   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([proposalId, sortOrder])
}

model ProposalAttachment {
  id         Int      @id @default(autoincrement())
  proposalId Int
  category   String   @db.VarChar(100)
  fileName   String
  fileUrl    String?  @db.Text
  notes      String?  @db.Text
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([proposalId, sortOrder])
}

// ─── TIME ENTRIES ────────────────────────────────────

model TimeEntry {
  id                   Int       @id @default(autoincrement())
  userId               Int
  workType             WorkType?
  jobId                Int?
  clockIn              DateTime
  clockOut             DateTime?

  /// DEPRECATED as of Commit 2 (payroll engine).
  /// Historical rows retain their existing values. New entries written by
  /// the payroll engine populate grossHours and paidHours instead.
  /// Do not write to this field from new code.
  hoursWorked          Decimal?  @db.Decimal(8, 2)

  /// DEPRECATED as of Commit 2 (payroll engine).
  /// Historical rows retain their existing values. New entries written by
  /// the payroll engine track breaks via breakStartedAt / breakEndedAt and
  /// store derived values in breakDurationMinutes / breakDeductionMinutes.
  breakMinutes         Int       @default(0)
  notes                String?
  notAtJobsiteReason   String?
  clockInLatitude      Decimal?  @db.Decimal(10, 7)
  clockInLongitude     Decimal?  @db.Decimal(10, 7)
  clockOutLatitude     Decimal?  @db.Decimal(10, 7)
  clockOutLongitude    Decimal?  @db.Decimal(10, 7)
  clockInAccuracy      Decimal?  @db.Decimal(8, 2)
  clockOutAccuracy     Decimal?  @db.Decimal(8, 2)
  isManual             Boolean   @default(false)
  specialPayEnabled    Boolean   @default(false)
  hourlyRateAdjustment Decimal   @default(0) @db.Decimal(10, 2)
  rateType             TimeRateType @default(regular)
  travelHours          Decimal?  @db.Decimal(8, 2)
  overtimeOverride     Boolean   @default(false)
  reviewStatus         TimeReviewStatus @default(pending)
  managerNotes         String?   @db.Text
  approvedById         Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // ─── Payroll engine fields (Commit 2) ────────────────────────────────

  // Hours
  grossHours            Decimal?  @db.Decimal(8, 2)
  paidHours             Decimal?  @db.Decimal(8, 2)

  // Raw break timestamps
  breakStartedAt        DateTime?
  breakEndedAt          DateTime?

  // Rounded payroll timestamps
  roundedClockIn        DateTime?
  roundedClockOut       DateTime?
  roundedBreakStartedAt DateTime?
  roundedBreakEndedAt   DateTime?

  // Break calculations
  breakDurationMinutes  Int?
  breakDeductionMinutes Int       @default(0)
  lateBreakMinutes      Int       @default(0)

  // Payroll metadata
  calcVersion           Int       @default(1)
  attendanceFlags       Json?

  user                  User      @relation(fields: [userId], references: [id])
  job                   Job?      @relation(fields: [jobId], references: [id])
  approvedBy            User?     @relation("ApprovedTimeEntries", fields: [approvedById], references: [id])

  @@index([userId])
  @@index([jobId])
  @@index([clockIn])
  @@index([clockOut])
  @@index([userId, clockOut])
}

// ─── EXPENSES ────────────────────────────────────────

model Expense {
  id            Int             @id @default(autoincrement())
  jobId         Int?
  submittedById Int
  approvedById  Int?
  vendor        String?
  category      ExpenseCategory
  amount        Decimal         @db.Decimal(12, 2)
  expenseDate   DateTime
  description   String?
  receiptUrl    String?
  extractedData Json?
  status        ExpenseStatus   @default(pending)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  job         Job?  @relation(fields: [jobId], references: [id])
  submittedBy User  @relation("SubmittedExpenses", fields: [submittedById], references: [id])
  approvedBy  User? @relation("ApprovedExpenses", fields: [approvedById], references: [id])

  @@index([jobId])
  @@index([submittedById])
  @@index([expenseDate])
  @@index([category])
}

// ─── INVOICES ────────────────────────────────────────

model Invoice {
  id              Int           @id @default(autoincrement())
  customerId      Int
  jobId           Int
  invoiceNumber   String        @unique @db.VarChar(20)
  title           String
  status          InvoiceStatus @default(draft)
  subtotal        Decimal       @db.Decimal(12, 2)
  tax             Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  amountPaid      Decimal       @default(0) @db.Decimal(12, 2)
  amountRemaining Decimal       @db.Decimal(12, 2)
  dueDate         DateTime?
  notes           String?
  pdfUrl          String?
  sentAt          DateTime?
  createdById     Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer  Customer          @relation(fields: [customerId], references: [id])
  job       Job               @relation(fields: [jobId], references: [id])
  createdBy User              @relation(fields: [createdById], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@index([jobId])
  @@index([customerId])
  @@index([status])
}

model InvoiceLineItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── PAYMENTS ────────────────────────────────────────

model Payment {
  id            Int           @id @default(autoincrement())
  jobId         Int
  invoiceId     Int?
  amount        Decimal       @db.Decimal(12, 2)
  dateReceived  DateTime
  method        PaymentMethod @default(check)
  status        PaymentStatus @default(received)
  checkNumber   String?       @db.VarChar(50)
  bank          String?       @db.VarChar(200)
  memo          String?
  attachmentUrl String?
  clearedDate   DateTime?
  recordedById  Int
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  job        Job      @relation(fields: [jobId], references: [id])
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])
  recordedBy User     @relation(fields: [recordedById], references: [id])

  @@index([jobId])
  @@index([invoiceId])
  @@index([dateReceived])
}

// ─── AUTOMATIONS ─────────────────────────────────────

model AutomationTemplate {
  id                 Int            @id @default(autoincrement())
  name               AutomationName @unique
  displayName        String
  description        String?
  trigger            String
  isEnabled          Boolean        @default(true)
  stopOnReply        Boolean        @default(true)
  stopOnLinkClick    Boolean        @default(false)
  businessHoursStart Int            @default(9)
  businessHoursEnd   Int            @default(18)
  businessDays       Int[]          @default([1, 2, 3, 4, 5])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  steps AutomationStep[]
  runs  AutomationRun[]
}

model AutomationStep {
  id             Int               @id @default(autoincrement())
  templateId     Int
  stepNumber     Int
  channel        AutomationChannel @default(sms)
  delayMinutes   Int
  messageContent String            @db.Text
  emailSubject   String?
  isEnabled      Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  template AutomationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, stepNumber])
  @@index([templateId])
}

model AutomationRun {
  id             Int              @id @default(autoincrement())
  opportunityId  Int
  templateId     Int
  currentStep    Int              @default(0)
  status         AutomationStatus @default(active)
  nextActionAt   DateTime
  contactReplied Boolean          @default(false)
  lastActionAt   DateTime?
  metadata       Json
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  opportunity       Opportunity        @relation(fields: [opportunityId], references: [id])
  template          AutomationTemplate @relation(fields: [templateId], references: [id])
  reviewSubmissions ReviewSubmission[]

  @@index([status, nextActionAt])
  @@index([opportunityId])
}

// ─── REVIEWS ─────────────────────────────────────────

model ReviewSubmission {
  id                 Int       @id @default(autoincrement())
  automationRunId    Int?
  customerId         Int
  token              String    @unique @db.VarChar(64)
  rating             Int
  feedback           String?   @db.Text
  redirectedToGoogle Boolean   @default(false)
  submittedAt        DateTime?
  createdAt          DateTime  @default(now())

  automationRun AutomationRun? @relation(fields: [automationRunId], references: [id])
  customer      Customer       @relation(fields: [customerId], references: [id])

  @@index([token])
  @@index([customerId])
}

// ─── AUDIT LOGS ──────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String   @db.VarChar(100)
  entityType String   @db.VarChar(50)
  entityId   Int
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── CONFIG ──────────────────────────────────────────

model Config {
  id                Int      @id @default(1)
  companyName       String   @default("I.S Painting Corp.")
  companyPhone      String?
  companyEmail      String?
  companyAddress    String?
  googleReviewUrl   String?
  logoUrl           String?
  defaultWcPercent  Decimal  @default(17.5) @db.Decimal(5, 2)
  defaultGlPercent  Decimal  @default(7.5) @db.Decimal(5, 2)
  defaultOverhead   Decimal  @default(12.0) @db.Decimal(5, 2)
  defaultMarkup     Decimal  @default(27.0) @db.Decimal(5, 2)
