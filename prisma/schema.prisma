// Prisma schema — I.S Painting Business Manager

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────

enum UserRole {
  admin
  employee
}

enum JobStatus {
  estimate
  sent
  approved
  active
  completed
  on_hold
  cancelled
}

enum JobType {
  interior
  exterior
  both
  commercial
  other
}

enum OpportunityPipeline {
  sales
  not_interested
}

enum OpportunityStage {
  new_lead
  onboarding
  not_answered
  follow_up
  estimate_sent
  approval
  service_delivery
  review
  no_reply
  lost
  not_qualified
}

enum OpportunityStatus {
  open
  won
  lost
}

enum InvoiceStatus {
  draft
  sent
  partial
  paid
  overdue
  cancelled
}

enum PaymentMethod {
  check
  cash
  credit_card
  bank_transfer
  other
}

enum PaymentStatus {
  received
  deposited
  cleared
  bounced
}

enum ExpenseCategory {
  materials
  labor
  equipment
  subcontractor
  travel
  office
  other
}

enum ExpenseStatus {
  pending
  approved
  rejected
}

enum InventoryCategory {
  paint
  primer
  caulk
  tape
  tools
  supplies
  other
}

enum AutomationName {
  follow_up
  not_answered
  review_request
  form_submit
}

enum AutomationStatus {
  active
  paused
  completed
  failed
}

enum AutomationChannel {
  sms
  email
}

// ─── USERS ───────────────────────────────────────────

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String
  password   String
  role       UserRole @default(employee)
  phone      String?  @db.VarChar(20)
  hourlyRate Decimal? @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  timeEntries           TimeEntry[]
  expenses              Expense[]               @relation("SubmittedExpenses")
  approvedExpenses      Expense[]               @relation("ApprovedExpenses")
  payments              Payment[]
  invoicesCreated       Invoice[]
  auditLogs             AuditLog[]
  assignedOpportunities Opportunity[]
  jobAssignments        EmployeeJobAssignment[]

  @@index([role])
  @@index([isActive])
}

// ─── CUSTOMERS ───────────────────────────────────────

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  email     String?
  phone     String?   @db.VarChar(30)
  address   String?
  city      String?   @db.VarChar(100)
  state     String?   @db.VarChar(50)
  zipCode   String?   @db.VarChar(20)
  source    String?   @db.VarChar(100)
  tags      String[]
  notes     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  jobs              Job[]
  opportunities     Opportunity[]
  invoices          Invoice[]
  reviewSubmissions ReviewSubmission[]

  @@index([deletedAt])
  @@index([name])
}

// ─── JOBS ────────────────────────────────────────────

model Job {
  id             Int       @id @default(autoincrement())
  customerId     Int
  opportunityId  Int?      @unique
  estimateNumber String    @unique @db.VarChar(20)
  name           String
  status         JobStatus @default(estimate)
  jobType        JobType   @default(interior)

  address        String?
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(50)
  zipCode        String?  @db.VarChar(20)
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)
  geofenceRadius Int      @default(100)

  scopeOfWork String? @db.Text
  notes       String? @db.Text

  materialsBudget      Decimal @default(0) @db.Decimal(12, 2)
  laborBudget          Decimal @default(0) @db.Decimal(12, 2)
  wcPercent            Decimal @default(0) @db.Decimal(5, 2)
  glPercent            Decimal @default(0) @db.Decimal(5, 2)
  overheadPercent      Decimal @default(0) @db.Decimal(5, 2)
  markupPercent        Decimal @default(0) @db.Decimal(5, 2)
  taxPercent           Decimal @default(0) @db.Decimal(5, 2)
  subtotalBeforeMarkup Decimal @default(0) @db.Decimal(12, 2)
  totalEstimate        Decimal @default(0) @db.Decimal(12, 2)
  contractAmount       Decimal @default(0) @db.Decimal(12, 2)
  budgetLocked         Boolean @default(false)

  priceBreakdownJson Json?

  sentAt     DateTime?
  approvedAt DateTime?
  startDate  DateTime?
  endDate    DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer    Customer                @relation(fields: [customerId], references: [id])
  opportunity Opportunity?            @relation(fields: [opportunityId], references: [id])
  materials   JobMaterial[]
  labor       JobLabor[]
  timeEntries TimeEntry[]
  expenses    Expense[]
  invoices    Invoice[]
  payments    Payment[]
  assignments EmployeeJobAssignment[]

  @@index([customerId])
  @@index([status])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model JobMaterial {
  id              Int      @id @default(autoincrement())
  jobId           Int
  inventoryItemId Int?
  name            String
  description     String?
  quantity        Decimal  @db.Decimal(10, 2)
  unit            String   @db.VarChar(50)
  unitCost        Decimal  @db.Decimal(10, 2)
  totalCost       Decimal  @db.Decimal(12, 2)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([jobId])
}

model JobLabor {
  id         Int      @id @default(autoincrement())
  jobId      Int
  role       String   @db.VarChar(100)
  employeeId Int?
  hours      Decimal  @db.Decimal(8, 2)
  hourlyCost Decimal  @db.Decimal(8, 2)
  totalCost  Decimal  @db.Decimal(12, 2)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model EmployeeJobAssignment {
  id         Int      @id @default(autoincrement())
  userId     Int
  jobId      Int
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

// ─── INVENTORY ───────────────────────────────────────

model InventoryItem {
  id            Int               @id @default(autoincrement())
  name          String
  description   String?
  category      InventoryCategory
  unit          String            @db.VarChar(50)
  costPerUnit   Decimal           @db.Decimal(10, 2)
  sellingPrice  Decimal?          @db.Decimal(10, 2)
  currentStock  Decimal           @default(0) @db.Decimal(10, 2)
  minStockLevel Decimal           @default(0) @db.Decimal(10, 2)
  supplier      String?
  sku           String?           @db.VarChar(100)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  jobMaterials JobMaterial[]

  @@index([category])
  @@index([isActive])
  @@index([name])
}

// ─── OPPORTUNITIES ───────────────────────────────────

model Opportunity {
  id                 Int                 @id @default(autoincrement())
  customerId         Int
  name               String
  pipeline           OpportunityPipeline @default(sales)
  stage              OpportunityStage    @default(new_lead)
  status             OpportunityStatus   @default(open)
  leadValue          Decimal?            @db.Decimal(12, 2)
  source             String?             @db.VarChar(100)
  assignedToId       Int?
  notes              String?             @db.Text
  lastStageChangedAt DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  customer       Customer        @relation(fields: [customerId], references: [id])
  job            Job?
  assignedTo     User?           @relation(fields: [assignedToId], references: [id])
  automationRuns AutomationRun[]

  @@index([customerId])
  @@index([pipeline, stage])
  @@index([stage])
}

// ─── TIME ENTRIES ────────────────────────────────────

model TimeEntry {
  id                Int       @id @default(autoincrement())
  userId            Int
  jobId             Int?
  clockIn           DateTime
  clockOut          DateTime?
  hoursWorked       Decimal?  @db.Decimal(8, 2)
  breakMinutes      Int       @default(0)
  notes             String?
  clockInLatitude   Decimal?  @db.Decimal(10, 7)
  clockInLongitude  Decimal?  @db.Decimal(10, 7)
  clockOutLatitude  Decimal?  @db.Decimal(10, 7)
  clockOutLongitude Decimal?  @db.Decimal(10, 7)
  clockInAccuracy   Decimal?  @db.Decimal(8, 2)
  clockOutAccuracy  Decimal?  @db.Decimal(8, 2)
  isManual          Boolean   @default(false)
  approvedById      Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
  job  Job? @relation(fields: [jobId], references: [id])

  @@index([userId])
  @@index([jobId])
  @@index([clockIn])
  @@index([clockOut])
  @@index([userId, clockOut])
}

// ─── EXPENSES ────────────────────────────────────────

model Expense {
  id            Int             @id @default(autoincrement())
  jobId         Int?
  submittedById Int
  approvedById  Int?
  vendor        String?
  category      ExpenseCategory
  amount        Decimal         @db.Decimal(12, 2)
  expenseDate   DateTime
  description   String?
  receiptUrl    String?
  extractedData Json?
  status        ExpenseStatus   @default(pending)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  job         Job?  @relation(fields: [jobId], references: [id])
  submittedBy User  @relation("SubmittedExpenses", fields: [submittedById], references: [id])
  approvedBy  User? @relation("ApprovedExpenses", fields: [approvedById], references: [id])

  @@index([jobId])
  @@index([submittedById])
  @@index([expenseDate])
  @@index([category])
}

// ─── INVOICES ────────────────────────────────────────

model Invoice {
  id              Int           @id @default(autoincrement())
  customerId      Int
  jobId           Int
  invoiceNumber   String        @unique @db.VarChar(20)
  title           String
  status          InvoiceStatus @default(draft)
  subtotal        Decimal       @db.Decimal(12, 2)
  tax             Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  amountPaid      Decimal       @default(0) @db.Decimal(12, 2)
  amountRemaining Decimal       @db.Decimal(12, 2)
  dueDate         DateTime?
  notes           String?
  pdfUrl          String?
  sentAt          DateTime?
  createdById     Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer  Customer          @relation(fields: [customerId], references: [id])
  job       Job               @relation(fields: [jobId], references: [id])
  createdBy User              @relation(fields: [createdById], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@index([jobId])
  @@index([customerId])
  @@index([status])
}

model InvoiceLineItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── PAYMENTS ────────────────────────────────────────

model Payment {
  id            Int           @id @default(autoincrement())
  jobId         Int
  invoiceId     Int?
  amount        Decimal       @db.Decimal(12, 2)
  dateReceived  DateTime
  method        PaymentMethod @default(check)
  status        PaymentStatus @default(received)
  checkNumber   String?       @db.VarChar(50)
  bank          String?       @db.VarChar(200)
  memo          String?
  attachmentUrl String?
  clearedDate   DateTime?
  recordedById  Int
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  job        Job      @relation(fields: [jobId], references: [id])
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])
  recordedBy User     @relation(fields: [recordedById], references: [id])

  @@index([jobId])
  @@index([invoiceId])
  @@index([dateReceived])
}

// ─── AUTOMATIONS ─────────────────────────────────────

model AutomationTemplate {
  id                 Int            @id @default(autoincrement())
  name               AutomationName @unique
  displayName        String
  description        String?
  trigger            String
  isEnabled          Boolean        @default(true)
  stopOnReply        Boolean        @default(true)
  stopOnLinkClick    Boolean        @default(false)
  businessHoursStart Int            @default(9)
  businessHoursEnd   Int            @default(18)
  businessDays       Int[]          @default([1, 2, 3, 4, 5])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  steps AutomationStep[]
  runs  AutomationRun[]
}

model AutomationStep {
  id             Int               @id @default(autoincrement())
  templateId     Int
  stepNumber     Int
  channel        AutomationChannel @default(sms)
  delayMinutes   Int
  messageContent String            @db.Text
  emailSubject   String?
  isEnabled      Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  template AutomationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, stepNumber])
  @@index([templateId])
}

model AutomationRun {
  id             Int              @id @default(autoincrement())
  opportunityId  Int
  templateId     Int
  currentStep    Int              @default(0)
  status         AutomationStatus @default(active)
  nextActionAt   DateTime
  contactReplied Boolean          @default(false)
  lastActionAt   DateTime?
  metadata       Json
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  opportunity       Opportunity        @relation(fields: [opportunityId], references: [id])
  template          AutomationTemplate @relation(fields: [templateId], references: [id])
  reviewSubmissions ReviewSubmission[]

  @@index([status, nextActionAt])
  @@index([opportunityId])
}

// ─── REVIEWS ─────────────────────────────────────────

model ReviewSubmission {
  id                 Int       @id @default(autoincrement())
  automationRunId    Int?
  customerId         Int
  token              String    @unique @db.VarChar(64)
  rating             Int
  feedback           String?   @db.Text
  redirectedToGoogle Boolean   @default(false)
  submittedAt        DateTime?
  createdAt          DateTime  @default(now())

  automationRun AutomationRun? @relation(fields: [automationRunId], references: [id])
  customer      Customer       @relation(fields: [customerId], references: [id])

  @@index([token])
  @@index([customerId])
}

// ─── AUDIT LOGS ──────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String   @db.VarChar(100)
  entityType String   @db.VarChar(50)
  entityId   Int
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── CONFIG ──────────────────────────────────────────

model Config {
  id                Int      @id @default(1)
  companyName       String   @default("I.S Painting Corp.")
  companyPhone      String?
  companyEmail      String?
  companyAddress    String?
  googleReviewUrl   String?
  logoUrl           String?
  defaultWcPercent  Decimal  @default(17.5) @db.Decimal(5, 2)
  defaultGlPercent  Decimal  @default(7.5) @db.Decimal(5, 2)
  defaultOverhead   Decimal  @default(12.0) @db.Decimal(5, 2)
  defaultMarkup     Decimal  @default(27.0) @db.Decimal(5, 2)
  defaultTaxPercent Decimal  @default(0) @db.Decimal(5, 2)
  twilioFromNumber  String?
  reminderEmailTo   String?
  updatedAt         DateTime @updatedAt
}
